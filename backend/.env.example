# Environment variables for application configuration

# AES-256 encryption key used to encrypt and decrypt the NWC URL
ENCRYPTION_KEY=replace_with_a_new_64_character_hex_key

# Credentials used by the API to connect to PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=replace_with_database_password
DB_NAME=railway

# Used only by local Docker Compose; Railway provisions managed PostgreSQL and does not use them.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_database_password
POSTGRES_DB=railway


# API connection when running directly on your machine (npm run start:dev).
# Docker Compose replaces DB_HOST and REDIS_HOST inside the container with
# postgres_db and redis_cache, respectively. Do not change these values for Compose.
DB_HOST=localhost
DB_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379

# Local Docker Compose Redis does not use authentication: leave these empty.
# Set them only when connecting the API to a protected external Redis instance.
REDIS_USERNAME=
REDIS_PASSWORD=

# Secret used to sign sessions. Generate a new one and keep it private.
JWT_SECRET=replace_with_a_long_random_secret

# OpenRouter / LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Platform identity on Nostr. PLATFORM_NPUB must correspond to PLATFORM_NSEC.
# NIP-19 nsec/npub or 64-character hexadecimal keys are accepted.
PLATFORM_NSEC=
PLATFORM_NPUB=

# NWC wallet that receives fees (requires make_invoice and lookup_invoice)
PLATFORM_NWC_URL=

# Nostr relay used to listen for and publish events
NOSTR_RELAY_URL=wss://relay.damus.io
