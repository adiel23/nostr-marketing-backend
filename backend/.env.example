// variables de entorno para la configuración de la aplicación

# Clave de encriptación (AES-256) usada para cifrar y descifrar la nwc url
ENCRYPTION_KEY=replace_with_a_new_64_character_hex_key

# Credenciales que usa la API para conectarse a PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=replace_with_database_password
DB_NAME=railway

# Solo para Docker Compose local; Railway crea PostgreSQL administrado y no las usa.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_database_password
POSTGRES_DB=railway


# Puertos y Hosts
DB_HOST=localhost
DB_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Secreto para firmar las sesiones. Genera uno nuevo y no lo compartas.
JWT_SECRET=replace_with_a_long_random_secret

# OpenRouter / LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Identidad de la plataforma en Nostr (nsec o hex de 64 caracteres)
PLATFORM_NSEC=

# Wallet NWC receptora de los fees (requiere make_invoice y lookup_invoice)
PLATFORM_NWC_URL=

# Relay de Nostr para escuchar y publicar eventos
NOSTR_RELAY_URL=wss://relay.damus.io
