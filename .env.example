// variables de entorno para la configuración de la aplicación

# Clave de encriptación (AES-256) usada para cifrar y descifrar la nwc url
ENCRYPTION_KEY=024519ba5755838db62658099c9cec432d7a62859c9c17d587eea639067c8911

# Credenciales maestras (Se usan para crear la DB y para que la API se conecte)
DB_USERNAME=root
DB_PASSWORD=1234
DB_NAME=nostr_marketing_db

# Puertos y Hosts
DB_HOST=postgres_db
DB_PORT=5432
REDIS_HOST=redis_cache
REDIS_PORT=6379

# OpenRouter / LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Identidad de la plataforma en Nostr (nsec o hex de 64 caracteres)
PLATFORM_NSEC=

# Relay de Nostr para escuchar y publicar eventos
NOSTR_RELAY_URL=wss://relay.damus.io