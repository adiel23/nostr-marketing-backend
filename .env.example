# Aplicación
PORT=3000

# Bull Board queda inaccesible por defecto. Solo habilÃ­telo tras una red privada o proxy TLS.
BULL_BOARD_ENABLED=false
BULL_BOARD_USERNAME=
BULL_BOARD_PASSWORD=

# Secreto para firmar JWT. Genere uno distinto para cada entorno.
# Ejemplo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# PostgreSQL (los valores de host son los nombres de servicio de docker-compose)
DB_HOST=postgres_db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=nostr_marketing

# Redis
REDIS_HOST=redis_cache
REDIS_PORT=6379

# Clave AES-256 para cifrar las URL NWC. Debe tener 64 caracteres hexadecimales.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# OpenRouter / LLM (opcional: sin clave, el servicio usa un fallback sin match)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Identidad de la plataforma Nostr. NSEC acepta nsec o hex de 64 caracteres.
PLATFORM_NSEC=
# NPUB acepta npub o hex de 64 caracteres.
PLATFORM_NPUB=

# Relay de Nostr para escuchar y publicar eventos
NOSTR_RELAY_URL=wss://relay.damus.io
# Relay público que se anuncia al solicitar invoices NIP-57. Si se omite, usa NOSTR_RELAY_URL.
NOSTR_ZAP_RELAY_URL=
# Relay where the platform publishes promotional replies. Defaults to NOSTR_RELAY_URL.
NOSTR_PUBLISH_RELAY_URL=

# Solo para wallets NWC que no responden al evento NIP-47 service-info (kind 13194).
NWC_FORCE_NIP04=false
